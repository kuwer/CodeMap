{
  "name": "codemap",
  "displayName": "CodeMap — Project Visualizer",
  "description": "Visualize project structure, function call graphs, and file dependencies. Built for onboarding new developers fast.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codemap.showGraph",
        "title": "CodeMap: Show Project Graph"
      },
      {
        "command": "codemap.showFileGraph",
        "title": "CodeMap: Show Call Graph for This File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "codemap.showFileGraph",
          "when": "resourceExtname == .js || resourceExtname == .ts || resourceExtname == .tsx || resourceExtname == .jsx",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "codemap.showFileGraph",
          "when": "resourceExtname == .js || resourceExtname == .ts || resourceExtname == .tsx || resourceExtname == .jsx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@types/babel__traverse": "^7.20.0"
  }
}
